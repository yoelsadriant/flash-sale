{
  "name": "flash-sale-backend",
  "version": "1.0.0",
  "description": "Flash Sale backend — Express + Redis (Lua) + DynamoDB.",
  "main": "src/api/handler.ts",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "npm-run-all --serial infra:up bootstrap cleanport offline",
    "stop": "npm run infra:down",
    "build": "tsup",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "jest --coverage --runInBand",
    "test:unit": "jest tests/unit --coverage --runInBand",
    "test:integration": "jest tests/integration --coverage --runInBand",
    "stress": "artillery run --output stress-report.json tests/stress/flash-sale.yml && ts-node tests/stress/verify-stress.ts && artillery report stress-report.json",
    "seed": "ts-node scripts/seed.ts",
    "infra:up": "docker compose up -d --wait",
    "infra:down": "docker compose down",
    "bootstrap": "ts-node scripts/bootstrap.ts",
    "cleanport": "lsof -ti:4000 | xargs kill -9 2>/dev/null || true",
    "offline": "tsup && serverless offline start --stage local"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/client-sqs": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "aws-jwt-verify": "^4.0.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "pino": "^9.2.0",
    "pino-http": "^10.1.0",
    "serverless-http": "^3.2.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.143",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.10",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "artillery": "^2.0.17",
    "aws-sdk-client-mock": "^4.0.1",
    "eslint": "^8.57.0",
    "ioredis-mock": "^8.9.0",
    "jest": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "pino-pretty": "^13.1.3",
    "serverless": "^3.39.0",
    "serverless-offline": "^13.6.0",
    "serverless-offline-sqs": "^8.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.4",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.5.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "collectCoverageFrom": [
      "src/services/**/*.ts",
      "src/api/routes/**/*.ts",
      "src/api/middleware/**/*.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 90,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    },
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "isolatedModules": true
        }
      ]
    }
  }
}
