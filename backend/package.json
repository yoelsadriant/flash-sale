{
  "name": "flash-sale-backend",
  "version": "1.0.0",
  "description": "Flash Sale backend — Express + Redis (Lua) + DynamoDB.",
  "main": "src/api/handler.ts",
  "scripts": {
    "infra:up": "docker compose up -d --wait",
    "infra:down": "docker compose down",
    "bootstrap": "ts-node scripts/bootstrap.ts",
    "cleanport": "lsof -ti:4000 | xargs kill -9 2>/dev/null || true",
    "offline": "tsc && serverless offline start --stage local",
    "watch": "tsc --watch",
    "start": "npm-run-all --serial infra:up bootstrap build cleanport offline",
    "stop": "npm run infra:down",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "deploy": "serverless deploy",
    "test": "jest --runInBand",
    "test:unit": "jest tests/unit --runInBand",
    "test:integration": "jest tests/integration --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "stress": "artillery run tests/stress/flash-sale.yml",
    "stress:report": "artillery run --output stress-report.json tests/stress/flash-sale.yml && artillery report stress-report.json",
    "seed": "ts-node scripts/seed.ts",
    "lint": "eslint src tests --ext .ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/client-sqs": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "aws-jwt-verify": "^4.0.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "pino": "^9.2.0",
    "pino-http": "^10.1.0",
    "serverless-http": "^3.2.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.143",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "artillery": "^2.0.17",
    "aws-sdk-client-mock": "^4.0.1",
    "eslint": "^8.57.0",
    "ioredis-mock": "^8.9.0",
    "jest": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "pino-pretty": "^13.1.3",
    "serverless": "^3.39.0",
    "serverless-offline": "^13.6.0",
    "serverless-offline-sqs": "^8.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/services/**/*.ts",
      "src/api/routes/**/*.ts",
      "src/api/middleware/**/*.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "isolatedModules": true
        }
      ]
    }
  }
}
