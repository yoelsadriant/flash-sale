# Local-dev overrides — all of these have sensible defaults for local mode.
# Copy to .env only if you need to change a value.

STAGE=local
AUTH_MODE=local

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# SQS (ElasticMQ)
PURCHASE_QUEUE_URL=http://localhost:9324/000000000000/PurchaseQueue
SQS_ENDPOINT=http://localhost:9324

# DynamoDB Local
DDB_ENDPOINT=http://localhost:8000
PURCHASES_TABLE=flash-sale-purchases-local
PRODUCTS_TABLE=flash-sale-products-local

# Cognito (only needed for non-local stages)
# COGNITO_USER_POOL_ID=ap-southeast-1_xxxxxxx
# COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxx
