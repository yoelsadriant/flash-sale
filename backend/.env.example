# Local-dev environment variables.
STAGE=local
AUTH_MODE=local

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# SQS (ElasticMQ)
PURCHASE_QUEUE_URL=http://localhost:9324/000000000000/PurchaseQueue
SQS_ENDPOINT=http://localhost:9324

# DynamoDB Local
DDB_ENDPOINT=http://localhost:8000
PURCHASES_TABLE=flash-sale-purchases-local
SALES_TABLE=flash-sale-sales-local

# Sale config
PRODUCT_ID=PROD-LIMITED-001
INITIAL_STOCK=100
SALE_START=2026-01-01T00:00:00Z
SALE_END=2030-12-31T23:59:59Z

# Cognito (only used in non-local stages)
# COGNITO_USER_POOL_ID=ap-southeast-1_xxxxxxx
# COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxx
